{{!< default}}

<div class="gh-page">
    <div class="gh-container gh-terminal-layout">
        <section class="gh-terminal-main">
            <p class="gh-command-line">
                <span class="gh-command-prompt">visitor@{{@site.title}}:~$</span>
                <span class="gh-command-text">ls ./authors</span>
            </p>

            {{#author}}
            <header class="gh-page-head">
                {{#if profile_image}}
                    <img class="gh-author-image" src="{{profile_image}}" alt="{{name}}" />
                {{/if}}

                <h1>{{name}}</h1>
                {{#if bio}}
                    <p>{{bio}}</p>
                {{/if}}

                <div class="gh-author-meta">
                    <div class="gh-author-links">
                        {{#if website}}
                            <a href="{{website}}" target="_blank" rel="noopener">Website</a>
                        {{/if}}
                        {{#if twitter}}
                            <a href="{{social_url type="twitter"}}" target="_blank" rel="noopener">Twitter</a>
                        {{/if}}
                        {{#if facebook}}
                            <a href="{{social_url type="facebook"}}" target="_blank" rel="noopener">Facebook</a>
                        {{/if}}
                    </div>
                </div>

                {{#if cover_image}}
                    <img class="gh-page-image" src="{{cover_image}}" alt="{{name}}" />
                {{/if}}
            </header>
            {{/author}}

            <div class="gh-postfeed">
            {{#foreach posts}}
                {{> "card"}}
            {{/foreach}}
            </div>
        </section>
    </div>
</div>
