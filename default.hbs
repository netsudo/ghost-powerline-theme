<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="{{asset "built/index.css"}}" />
    <script src="{{asset "built/index.js"}}" defer></script>

    <title>{{meta_title}}</title>

    {{ghost_head}}
    {{!-- Outputs important meta data and settings, should always be in <head> --}}

</head>
<body class="{{body_class}}">
<div class="gh-viewport">
    <div class="gh-shell">
        <header id="gh-head" class="gh-head">
            <div class="gh-head-top gh-container">
                <p class="gh-head-title">{{@site.title}}@hexed:~</p>
            </div>
            <div class="gh-head-navline gh-container">
                <div class="gh-head-brand">
                    <a class="gh-head-logo" href="{{@site.url}}">
                        {{#if @site.logo}}
                            <img src="{{@site.logo}}" alt="{{@site.title}}" />
                        {{else}}
                            {{@site.title}}
                        {{/if}}
                    </a>
                </div>
                <nav class="gh-head-menu" aria-label="Primary navigation">
                    {{navigation}}
                </nav>
                <div class="gh-head-actions">
                    {{#if @site.members_enabled}}
                        {{^if @member}}
                            <a class="gh-shell-action" href="{{@site.signup_url}}">subscribe</a>
                        {{else}}
                            <a class="gh-shell-action" href="#/portal/account">account</a>
                        {{/if}}
                    {{/if}}
                </div>
            </div>
        </header>

        <main class="gh-main">
            {{{body}}}
            {{!-- All content gets inserted here, index.hbs, post.hbs, etc --}}
        </main>
    </div>

    <footer class="gh-foot">
        <div class="gh-container">
            <div class="gh-foot-meta">
                <span>&copy; {{date format="YYYY"}} {{@site.title}}</span>
                <span class="gh-foot-separator">::</span>
                <span>{{@site.description}}</span>
            </div>
        </div>
    </footer>
</div>

{{!-- <foot> --}}
{{ghost_foot}}
{{!-- Outputs important scripts - should always be included before closing body tag --}}

</body>
</html>
