{{!< default}}
<div class="gh-page">
    <div class="gh-container gh-terminal-layout">
        <section class="gh-terminal-main">
            <p class="gh-command-line">
                <span class="gh-command-prompt">visitor@{{@site.title}}:~$</span>
                <span class="gh-command-text">ls ./posts</span>
            </p>

            <div class="gh-postfeed">
            {{#foreach posts}}
                {{> "card" page=../pagination.page }}
            {{/foreach}}
            </div>

            <noscript>
                <div class="gh-pagination">
                    {{pagination}}
                </div>
            </noscript>
        </section>

        <aside class="gh-terminal-sidebar">
            <section class="gh-sidebar-block">
                <p class="gh-command-line gh-command-line-sidebar">
                    <span class="gh-command-prompt">~$</span>
                    <span class="gh-command-text">whoami</span>
                </p>
                <h2 class="gh-sidebar-title">{{@site.title}}</h2>
                {{#if @site.description}}
                    <p class="gh-sidebar-copy">{{@site.description}}</p>
                {{/if}}
            </section>

            <section class="gh-sidebar-block">
                <p class="gh-command-line gh-command-line-sidebar">
                    <span class="gh-command-prompt">~$</span>
                    <span class="gh-command-text">cat ~/.links</span>
                </p>
                <div class="gh-sidebar-nav">
                    {{navigation type="secondary"}}
                </div>
            </section>
        </aside>
    </div>
</div>
