{{!< default}}
<div class="gh-page">
    <div class="gh-container gh-terminal-layout">
        <section class="gh-terminal-main">
            <p class="gh-command-line" data-terminal-step data-terminal-line>
                <span class="gh-command-prompt">visitor@{{@site.title}}:~$</span>
                <span class="gh-command-text" data-terminal-type>whoami</span>
            </p>

            <p class="gh-terminal-intro" data-terminal-step>{{@site.title}} {{#if @site.description}}- {{@site.description}}{{/if}}</p>

            <p class="gh-command-line" data-terminal-step data-terminal-line>
                <span class="gh-command-prompt">visitor@{{@site.title}}:~$</span>
                <span class="gh-command-text" data-terminal-type>cat ./posts/README</span>
            </p>

            <div class="gh-postfeed" data-terminal-step data-terminal-group>
            {{#foreach posts}}
                {{> "card" page=../pagination.page }}
            {{/foreach}}
            </div>

            <p class="gh-command-line gh-command-line-spaced" data-terminal-step data-terminal-line>
                <span class="gh-command-prompt">visitor@{{@site.title}}:~$</span>
                <span class="gh-command-text" data-terminal-type>ls -la ./posts/</span>
            </p>

            <div class="gh-terminal-listing" data-terminal-step data-terminal-group>
                <p data-terminal-item>total {{pagination.total}}</p>
                <p data-terminal-item>drwxr-xr-x  {{pagination.total}} posts  staff  4096  {{date format="MMM DD HH:mm"}} <span class="gh-dim">.</span></p>
                <p data-terminal-item>drwxr-xr-x  1 root   wheel  4096  {{date format="MMM DD HH:mm"}} <span class="gh-dim">..</span></p>
                {{#foreach posts}}
                    <p data-terminal-item>-rw-r--r--  1 post   post   {{date format="MMM DD YYYY"}}  <a href="{{url}}">{{slug}}.md</a></p>
                {{/foreach}}
            </div>

            <p class="gh-command-line gh-command-line-spaced gh-terminal-idle" data-terminal-step>
                <span class="gh-command-prompt">visitor@{{@site.title}}:~$</span>
                <span class="gh-terminal-idle-cursor" aria-hidden="true"></span>
            </p>

            <noscript>
                <div class="gh-pagination">
                    {{pagination}}
                </div>
            </noscript>
        </section>

        <aside class="gh-terminal-sidebar">
            <section class="gh-sidebar-block">
                <p class="gh-command-line gh-command-line-sidebar">
                    <span class="gh-command-prompt">~$</span>
                    <span class="gh-command-text">whoami</span>
                </p>
                <h2 class="gh-sidebar-title">{{@site.title}}</h2>
                {{#if @site.description}}
                    <p class="gh-sidebar-copy">{{@site.description}}</p>
                {{/if}}
            </section>

            <section class="gh-sidebar-block">
                <p class="gh-command-line gh-command-line-sidebar">
                    <span class="gh-command-prompt">~$</span>
                    <span class="gh-command-text">cat ~/.links</span>
                </p>
                <div class="gh-sidebar-nav">
                    {{navigation type="secondary"}}
                </div>
            </section>
        </aside>
    </div>
</div>
