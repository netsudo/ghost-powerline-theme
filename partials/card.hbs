{{!--
Re-usable card for linking to posts
--}}

<article class="gh-card {{post_class}}">
    <a class="gh-card-link" href="{{url}}">
        <div class="gh-card-content">
            <p class="gh-card-command"><span class="gh-command-prompt">-&gt;</span> open {{slug}}.md</p>
            <h2 class="gh-card-title">{{title}}</h2>
            <p>{{excerpt}}</p>
            <div class="gh-post-meta-container">
                <span class="gh-card-meta"><time datetime="{{date format="YYYY-MM-DD"}}">{{date format="YYYY-MM-DD"}}</time> <span class="bull">&bull;</span> {{reading_time}}</span>
                <div class="read-more">read more</div>
            </div>
        </div>
    </a>
</article>
